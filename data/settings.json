{
	"username": "ivy",
	"title": "~",
	"theme": {
		"name": "Gruvbox Material Dark",
		"backgroundColor": "#282828",
		"windowColor": "#3c3836",
		"textColor": "#ebdbb2",
		"black": "#1d2021",
		"red": "#fb4934",
		"green": "#b8bb26",
		"yellow": "#fabd2f",
		"blue": "#83a598",
		"magenta": "#d3869b",
		"cyan": "#8ec07c",
		"white": "#ebdbb2",
		"gray": "#928374"
	},
	"wallpaper": {
		"url": "https://raw.githubusercontent.com/52and2/start-page/refs/heads/main/data/assets/gruv-bg.png",
		"easing": "ease-in-out",
		"fadeIn": true,
		"blur": false
	},
	"terminal": {
		"fixedHeight": true,
		"windowGlow": false,
		"windowGlowColor": "#2E2736",
		"textGlow": false,
		"opacity": 100,
		"blur": 0
	},
	"prompt": {
		"ctrlC": true,
		"placeholder": "command...",
		"placeholderColor": "gray",
		"userColor": "green",
		"atColor": "gray",
		"hostColor": "magenta",
		"promptColor": "magenta",
		"promptSymbol": "❯",
		"caretColor": "green",
		"selectionBg": "yellow",
		"selectionFg": "black"
	},
	"fetch": {
		"timeFormat": "HH:mm",
		"dateFormat": "DD/MM/YYYY",
		"titleColor": "yellow",
		"image": "assets/default-icon.svg",
		"data": [
			"Time: {time}",
			"Date: {date}",
			"{seperator}",
			"OS: {osName} {osVersion}",
			"Theme: {theme}",
			"{seperator}",
			"Browser: {browser} {browserVersion}",
			"Engine: {engineName}",
			"{seperator}",
			"{colors}"
		]
	},
	"urlLaunch": {
		"target": "_self",
		"hoverColor": "magenta"
	},
	"search": {
		"default": "https://www.startpage.com/search?q={}",
		"target": "_self",
		"shortcutRegex": "(!?[A-Za-z0-9]+) (.*)",
		"shortcuts": [
			{
				"alias": "gh",
				"name": "Github Search",
				"url": "https://github.com/search?q={}"
			},
			{
				"alias": "if",
				"name": "Ifixit Search",
				"url": "https://www.ifixit.com/Search?query={}"
			},
			{
				"alias": "yt",
				"name": "Youtube Search",
				"url": "https://youtube.com/search?q={}"
			},
			{
				"alias": "r",
				"name": "Subreddit Search",
				"url": "https://reddit.com/r/{}"
			},
			{
				"alias": "w",
				"name": "Wikipedia Search",
				"url": "https://en.wikipedia.org/wiki/{}"
			}
		]
	},
	"sections": {
		"list": [
			{
				"title": "General",
				"color": "green",
				"align": "left",
				"links": [
					{
						"name": "Youtube",
						"url": "https://youtube.com",
						"icon": "mdi:youtube"
					},
					{
						"name": "Ebay",
						"url": "https://ebay.com",
						"icon": "mdi:basket"
					},
					{
						"name": "Wikipedia",
						"url": "https://en.wikipedia.org",
						"icon": "tabler:brand-wikipedia"
					}
				]
			},
			{
				"title": "Dev",
				"color": "magenta",
				"align": "left",
				"links": [
					{
						"name": "GitHub",
						"url": "https://github.com",
						"icon": "mdi:github"
					},
					{
						"name": "AUR",
						"url": "https://aur.archlinux.org/",
						"icon": "mdi:arch"
					},
					{
						"name": "Speedtest",
						"url": "https://speedtest.net",
						"icon": "tabler:brand-speedtest"
					}
				]
			},
			{
				"title": "Gaming",
				"color": "red",
				"align": "left",
				"links": [
					{
						"name": "Minecraft",
						"url": "https://minecraft.wiki",
						"icon": "tabler:brand-minecraft"
					},
					{
						"name": "Abiotic Factor",
						"url": "https://abioticfactor.wiki.gg/",
						"icon": "mdi:test-tube"
					},
					{
						"name": "VRC",
						"url": "https://vrchat.com/home",
						"icon": "tabler:cardboards-filled"
					}
				]
			}
		]
	}
}
